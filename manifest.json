{
  "manifest_version": 2,
  "name": "Schnipsel",
  "version": "0.1.0",

  "description": "Collect snippets of web content, collage it, index it, search it, share it.",
  "icons": {
    "32": "icons/schnipsel-32.png",
    "48": "icons/schnipsel-48.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "schnipsel@tomhumbert",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],

  "background": {
    "scripts": [
      "storage/store.js",
      "search/index.js",
      "background/background.js"
    ],
    "persistent": false
  },

  "browser_action": {
    "default_icon": "icons/schnipsel-32.png",
    "default_title": "Toggle Schnipsel sidebar"
  },

  "sidebar_action": {
    "default_icon": "icons/schnipsel-32.png",
    "default_title": "Schnipsel",
    "default_panel": "sidebar/sidebar.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_scripts/schnipsel.js"],
      "run_at": "document_idle"
    }
  ]
}
